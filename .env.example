# Copy to .env and fill in. Expected secrets per docs/TECH_ARCHITECTURE.md §10.
# Hosted Postgres (Neon) for the shared env — direct host for migrations/dev, -pooler host on
# Railway. For local tests, docker-compose Postgres works: postgres://postgres:postgres@localhost:5432/edge_desk
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/edge_desk?sslmode=require

# Where the ingestor POSTs derived events (the public ingest contract).
INGEST_API_URL=http://localhost:3000

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

LINKUP_API_KEY=

POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_DATA_URL=https://data-api.polymarket.com

HERMES_MODEL_PROVIDER_KEY=
# Hermes gateway API Server used by apps/workers. Keep the key separate from model keys.
HERMES_API_URL=http://127.0.0.1:8642
HERMES_API_KEY=
HERMES_API_MODEL=hermes-agent
HERMES_RUN_TIMEOUT_MS=45000
HERMES_REQUEST_TIMEOUT_MS=10000
HERMES_POLL_INTERVAL_MS=500
ORCHESTRATOR_POLL_INTERVAL_MS=1000

# Hermes webhook direct-delivery route for approved Telegram alerts.
HERMES_TELEGRAM_WEBHOOK_URL=http://127.0.0.1:8644/webhooks/edge-desk-alert
HERMES_TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_DELIVERY_TIMEOUT_MS=10000
TELEGRAM_MAX_ATTEMPTS=5
TELEGRAM_RETRY_BASE_MS=1000
TELEGRAM_RETRY_MAX_MS=60000
ALERT_SENDER_POLL_INTERVAL_MS=1000
MATCHER_POLL_INTERVAL_MS=1000
TELEGRAM_ALERT_CHAT_ID=

WORKER_ROLES=orchestrator,matcher,alert_sender
# OPENAI_API_KEY= (only if OpenAI is selected for matcher assistance)
# DODO_API_KEY=   (only when entitlements are enabled)
